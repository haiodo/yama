{
  "include": ["src/**/*"],
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "declaration": true,
    "strict": true,
    "sourceMap": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "inlineSources": true,
    "rootDirs": ["src"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "declarationDir": "types",
    "rootDir": "./src",
    "outDir": "./lib",
    "incremental": false,
    "isolatedModules": true
  }
}
